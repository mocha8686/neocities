---
import 'katex/dist/katex-swap.min.css';

import { getImage } from 'astro:assets';

import sky from '$src/assets/sky.jpg';
import Back from '$src/components/Back.astro';

import BaseLayout from './BaseLayout.astro';

const optimizedSky = await getImage({ src: sky });
---

<BaseLayout style={`--background-image: url("${optimizedSky.src}")`}>
	<main>
		<slot />

		<Back />
	</main>
</BaseLayout>

<style is:global>
	:root {
		/* stylelint-disable custom-property-empty-line-before */
		--cl-light: oklch(95% 0.01 115);
		--cl-dark: oklch(40% 0 90);
		--cl-accent: blue;

		--cl-outline: oklch(38% 0.1 24);
		--cl-container: oklch(38% 0.1 24 / 0.4);

		--ff-main: Tahoma, Verdana, Geneva, Arial, Helvetica, sans-serif;
		--ff-accent: var(--ff-main);

		--z-bg: -1000;
		/* stylelint-enable custom-property-empty-line-before */
	}

	body {
		min-height: 100lvh;

		font-family: var(--ff-main);
		color: var(--cl-dark);

		color-scheme: only dark;
		accent-color: var(--cl-accent);
		background: var(--cl-light);

		&::before {
			content: '';

			position: fixed;
			z-index: var(--z-bg);
			inset: 0;

			background: no-repeat top/100% auto var(--background-image);

			animation: parallax linear;
			animation-timeline: scroll();
		}
	}

	main {
		margin: 2rem clamp(1rem, 8vw - 0.75rem, 6rem);
		padding: 0.5rem 1rem;
		border: 1rem outset silver;

		background-color: var(--cl-light);
		box-shadow: 0px 5px 25px -10px var(--cl-dark);
	}

	a {
		color: var(--cl-accent);
	}

	@keyframes parallax {
		to {
			background-position-y: bottom;
		}
	}
</style>
