---
import type { ImageMetadata } from 'astro';
import type { HTMLAttributes } from 'astro/types';
import { Image } from 'astro:assets';

interface OtherProps {
	image: ImageMetadata;
	alt?: string;
	href: string;
	title: string;
	artist: string;
}

type Props = OtherProps & HTMLAttributes<'a'>;

const { image, alt, href, title, artist, ...props } = Astro.props;

const sizeRem = 6;
const size = 16 * sizeRem;
---

<a {href} target="_blank" rel="noreferrer" {...props}>
	<h3>{title}</h3>
	<p>{artist}</p>
	<Image
		src={image}
		alt={alt ?? `Cover art of ${title}`}
		width={size}
		height={size}
		class="cover"
	/>
</a>

<style define:vars={{ size: `${sizeRem}rem` }}>
	a {
		display: grid;
		grid-row: span 3;
		grid-template-areas: 'cover' 'title' 'artist';
		grid-template-columns: max-content;
		grid-template-rows: subgrid;
		row-gap: 0.25em;
		align-items: center;

		padding-block-end: 1em;

		color: inherit;
		text-decoration: none;
	}

	h3 {
		grid-area: title;
		font-size: 0.8rem;
	}

	p {
		grid-area: artist;
		font-size: 0.75rem;
	}

	h3,
	p {
		max-width: var(--size);
		margin: 0;
		text-align: right;
	}

	.cover {
		grid-area: cover;
	}
</style>
